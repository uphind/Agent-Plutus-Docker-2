# Agent Plutus Configuration
# Copy this file to .env and fill in your values before running docker compose up.

# ---------------------------------------------------------------------------
# Domain
# ---------------------------------------------------------------------------
# The subdomain where Agent Plutus will be accessible.
# Caddy uses this for TLS: public domain → auto Let's Encrypt,
# "localhost" → self-signed cert for testing.
DOMAIN="ai-analytics.company.com"

# ---------------------------------------------------------------------------
# Secrets (MUST change before production)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="change-me-to-a-32-char-secret!!"
AUTH_SECRET="change-me-auth-secret-32-chars!!"

# ---------------------------------------------------------------------------
# Database password (optional -- defaults to plutus_secret)
# ---------------------------------------------------------------------------
# POSTGRES_PASSWORD="a-strong-db-password"

# ---------------------------------------------------------------------------
# SSO Provider — "oidc" or "saml"
# ---------------------------------------------------------------------------
SSO_PROVIDER="oidc"

# OIDC settings (when SSO_PROVIDER=oidc)
# Works with: Microsoft Entra ID, Okta, Google Workspace, Auth0, Keycloak, PingFederate
# Redirect URI to register in your IdP: https://{DOMAIN}/api/auth/callback/oidc
SSO_ISSUER="https://login.microsoftonline.com/{tenant-id}/v2.0"
SSO_CLIENT_ID=""
SSO_CLIENT_SECRET=""

# SAML 2.0 settings (when SSO_PROVIDER=saml)
# Works with: AD FS, Shibboleth, any SAML 2.0 IdP
# ACS URL to register in your IdP: https://{DOMAIN}/api/auth/saml/acs
SSO_SAML_ENTRY_POINT="https://adfs.company.com/adfs/ls/"
SSO_SAML_ISSUER="https://ai-analytics.company.com"
SSO_SAML_CERT="base64-encoded-idp-signing-certificate"

# ---------------------------------------------------------------------------
# Demo mode — bypasses SSO (for internal testing only, never in production)
# ---------------------------------------------------------------------------
# DEMO_MODE="true"
