# Copy this file to .env and adjust values as needed.
# For Docker deployment, these are set in docker-compose.yml — you don't need a .env file.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://tokenear:tokenear_secret@localhost:5432/tokenear?schema=public"

# ---------------------------------------------------------------------------
# Encryption (AES-256-GCM for provider API keys)
# ---------------------------------------------------------------------------
ENCRYPTION_KEY="change-me-to-a-32-char-secret!!"

# ---------------------------------------------------------------------------
# Domain & TLS
# ---------------------------------------------------------------------------
# Set to your actual domain for production (auto Let's Encrypt via Caddy).
# "localhost" uses a self-signed cert for local/dev use.
DOMAIN="localhost"

# ---------------------------------------------------------------------------
# Auth (session encryption)
# ---------------------------------------------------------------------------
AUTH_SECRET="change-me-auth-secret-32-chars!!"
AUTH_URL="https://localhost"

# ---------------------------------------------------------------------------
# SSO Provider — set to "oidc" or "saml"
# ---------------------------------------------------------------------------
SSO_PROVIDER="oidc"

# OIDC settings (when SSO_PROVIDER=oidc)
# Works with Azure AD/Entra, Okta, Google Workspace, Auth0, Keycloak, etc.
SSO_ISSUER="https://login.microsoftonline.com/{tenant-id}/v2.0"
SSO_CLIENT_ID=""
SSO_CLIENT_SECRET=""

# SAML 2.0 settings (when SSO_PROVIDER=saml)
SSO_SAML_ENTRY_POINT="https://idp.example.com/sso/saml"
SSO_SAML_ISSUER="https://tokenear.company.com"
SSO_SAML_CERT="base64-encoded-idp-certificate"
