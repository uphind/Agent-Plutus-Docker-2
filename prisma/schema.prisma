generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  syncIntervalHours    Int       @default(6) @map("sync_interval_hours")
  dirSyncIntervalHours Int       @default(0) @map("dir_sync_interval_hours")
  relinkIntervalHours  Int       @default(0) @map("relink_interval_hours")
  lastRelinkAt         DateTime? @map("last_relink_at")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  users               OrgUser[]
  departments         Department[]
  teams               Team[]
  providerCredentials ProviderCredential[]
  usageRecords        UsageRecord[]
  syncLogs            SyncLog[]
  notifications       Notification[]
  cursorDau           CursorDau[]
  terminologyOverrides TerminologyOverride[]
  graphConfig         GraphConfig?
  fieldMappings       FieldMapping[]
  aiToolsConfig       AiToolsConfig?
  aiUsageLogs         AiUsageLog[]
  alertChannels       AlertChannel[]
  alertRules          AlertRule[]
  alertDeliveries     AlertDelivery[]
  slackInstallation   SlackInstallation?
  slackOAuthSettings  SlackOAuthSettings?
  teamsBotSettings    TeamsBotSettings?
  teamsConversations  TeamsConversation[]

  @@map("organizations")
}

model Department {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  name           String
  monthlyBudget  Decimal? @map("monthly_budget") @db.Decimal(12, 2)
  alertThreshold Int      @default(80) @map("alert_threshold")
  costCenter     String?  @map("cost_center")
  glCode         String?  @map("gl_code")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teams        Team[]
  users        OrgUser[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("departments")
}

model BenchmarkSnapshot {
  id                   String   @id @default(uuid())
  date                 DateTime @db.Date
  companySize          String   @map("company_size")
  medianCostPerDev     Decimal  @map("median_cost_per_dev") @db.Decimal(12, 2)
  medianAcceptRate     Decimal  @map("median_accept_rate") @db.Decimal(5, 4)
  medianCostPerLine    Decimal  @map("median_cost_per_line") @db.Decimal(12, 6)
  providerMix          Json     @map("provider_mix")
  sampleSize           Int      @map("sample_size")
  createdAt            DateTime @default(now()) @map("created_at")

  @@unique([date, companySize])
  @@map("benchmark_snapshots")
}

model ChargebackReport {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  month        String
  generatedAt  DateTime @default(now()) @map("generated_at")
  data         Json
  totalCost    Decimal  @map("total_cost") @db.Decimal(12, 2)

  @@index([orgId, month])
  @@map("chargeback_reports")
}

model Team {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  departmentId   String   @map("department_id")
  name           String
  monthlyBudget  Decimal? @map("monthly_budget") @db.Decimal(12, 2)
  alertThreshold Int      @default(80) @map("alert_threshold")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  users        OrgUser[]

  @@unique([orgId, departmentId, name])
  @@index([orgId])
  @@index([departmentId])
  @@map("teams")
}

model OrgUser {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  email          String
  name           String
  department     String?
  team           String?
  departmentId   String?  @map("department_id")
  teamId         String?  @map("team_id")
  jobTitle       String?  @map("job_title")
  employeeId     String?  @map("employee_id")
  status         String   @default("active")
  monthlyBudget  Decimal? @map("monthly_budget") @db.Decimal(12, 2)
  alertThreshold Int      @default(80) @map("alert_threshold")
  // Full Graph user object captured at sync time (manager, all
  // onPremisesExtensionAttribute*, address fields, etc.). Powers the
  // "Directory" tab on the user-detail page so admins can see every
  // attribute without us hardcoding columns for each.
  rawAttributes  Json?    @map("raw_attributes")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  departmentRef  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  teamRef        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  usageRecords   UsageRecord[]

  @@unique([orgId, email])
  @@index([orgId])
  @@index([department])
  @@index([team])
  @@index([departmentId])
  @@index([teamId])
  @@map("org_users")
}

enum Provider {
  anthropic
  anthropic_compliance
  anthropic_analytics
  openai
  gemini
  cursor
  vertex
  /// Microsoft 365 Copilot + Graph reports (Bearer access token, not a static vendor key).
  microsoft_copilot
  /// Lovable Cloud API (Bearer token from Lovable).
  lovable
  /// n8n instance REST API — credential JSON: { "v": 1, "baseUrl": "https://…", "apiKey": "…" }.
  n8n
}

model ProviderCredential {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  provider        Provider
  encryptedApiKey String   @map("encrypted_api_key")
  label           String?
  isActive        Boolean  @default(true) @map("is_active")
  lastSyncAt      DateTime? @map("last_sync_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@index([orgId])
  @@map("provider_credentials")
}

model UsageRecord {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  userId        String?  @map("user_id")
  provider      Provider
  model         String?
  date          DateTime @db.Date
  inputTokens   Int      @default(0) @map("input_tokens")
  outputTokens  Int      @default(0) @map("output_tokens")
  cachedTokens  Int      @default(0) @map("cached_tokens")
  requestsCount Int      @default(0) @map("requests_count")
  costUsd       Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)

  apiKeyId          String?  @map("api_key_id")
  inputAudioTokens  Int      @default(0) @map("input_audio_tokens")
  outputAudioTokens Int      @default(0) @map("output_audio_tokens")
  isBatch           Boolean  @default(false) @map("is_batch")

  linesAccepted   Int?   @map("lines_accepted")
  linesSuggested  Int?   @map("lines_suggested")
  acceptRate      Decimal? @map("accept_rate") @db.Decimal(5, 4)

  metadata      Json?
  userRef       String?  @map("user_ref")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user          OrgUser?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([orgId, userId, provider, model, date], name: "usage_dedup")
  @@index([orgId, date])
  @@index([orgId, provider])
  @@index([orgId, userId])
  @@index([provider, date])
  @@map("usage_records")
}

model SyncLog {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  provider   Provider
  status     String
  message    String?
  startedAt  DateTime @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, provider])
  @@map("sync_logs")
}

enum NotificationType {
  budget_alert
  anomaly
  sync_failure
  idle_seat
  suggestion
}

model Notification {
  id         String           @id @default(uuid())
  orgId      String           @map("org_id")
  type       NotificationType
  severity   String           @default("info")
  title      String
  message    String
  entityType String?          @map("entity_type")
  entityId   String?          @map("entity_id")
  isRead     Boolean          @default(false) @map("is_read")
  createdAt  DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isRead, createdAt])
  @@map("notifications")
}

model CursorDau {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  date      DateTime @db.Date
  dauCount  Int      @map("dau_count")
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, date])
  @@index([orgId])
  @@map("cursor_dau")
}

model TerminologyOverride {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  systemTerm String   @map("system_term")
  customTerm String   @map("custom_term")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, systemTerm])
  @@index([orgId])
  @@map("terminology_overrides")
}

model GraphConfig {
  id              String    @id @default(uuid())
  orgId           String    @unique @map("org_id")
  tenantId        String    @map("tenant_id")
  clientId        String    @map("client_id")
  encryptedSecret String    @map("encrypted_secret")
  graphEndpoint   String    @default("https://graph.microsoft.com/v1.0") @map("graph_endpoint")
  isActive        Boolean   @default(true) @map("is_active")
  lastSyncAt      DateTime? @map("last_sync_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("graph_configs")
}

model FieldMapping {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  entityType  String   @map("entity_type")
  sourceField String   @map("source_field")
  targetField String   @map("target_field")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, entityType, targetField])
  @@index([orgId])
  @@map("field_mappings")
}

/// Server-stored AI key used for in-app tools (mapping suggestions). Distinct
/// from the chatbot key, which lives only in the user's browser localStorage.
model AiToolsConfig {
  id              String   @id @default(uuid())
  orgId           String   @unique @map("org_id")
  provider        String
  model           String
  encryptedApiKey String   @map("encrypted_api_key")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("ai_tools_config")
}

/// Per-call log of AI calls (chatbot + AI tools) for the usage tracker.
/// Tokens come from each provider's response; cost is computed via the
/// model->price table or pulled from the official cost API when available.
model AiUsageLog {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  source       String
  provider     String
  model        String
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  cachedTokens Int      @default(0) @map("cached_tokens")
  costUsd      Decimal? @map("cost_usd") @db.Decimal(12, 6)
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, source, createdAt])
  @@map("ai_usage_logs")
}

enum AlertChannelKind {
  email_smtp
  slack_webhook
  slack_bot
  teams_webhook
  teams_bot
}

enum AlertTriggerKind {
  over_budget
  budget_warning
  anomaly
  inactive_user
  cost_spike
  no_budget
  high_cost_model
  underutilized
  sync_failure
  daily_digest
  weekly_digest
}

/// Where outbound alerts get sent. `config` stores adapter-specific JSON
/// (encrypted SMTP creds, webhook URL, slack channel id). Bot tokens live
/// in `SlackInstallation`, not here.
model AlertChannel {
  id              String           @id @default(uuid())
  orgId           String           @map("org_id")
  kind            AlertChannelKind
  name            String
  config          Json
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("alert_channels")
}

/// `recipients` is a JSON array of `{ kind: AlertRecipientKind, value?: string }`.
/// kinds: static_emails | org_admins | ad_users | ad_department | ad_team |
///        entity_owner | slack_channel | slack_user_email
/// `filter` is JSON like { departmentIds?: string[], teamIds?: string[],
///   providers?: string[], thresholdPct?: number }
model AlertRule {
  id              String             @id @default(uuid())
  orgId           String             @map("org_id")
  name            String
  trigger         AlertTriggerKind
  filter          Json               @default("{}")
  channelIds      String[]           @map("channel_ids")
  recipients      Json               @default("[]")
  throttleHours   Int                @default(24) @map("throttle_hours")
  muteUntil       DateTime?          @map("mute_until")
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  organization    Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, trigger])
  @@map("alert_rules")
}

/// Outbound audit log; doubles as the dedupe table for throttle windows.
model AlertDelivery {
  id              String             @id @default(uuid())
  orgId           String             @map("org_id")
  ruleId          String?            @map("rule_id")
  channelId       String?            @map("channel_id")
  trigger         AlertTriggerKind
  entityType      String?            @map("entity_type")
  entityId        String?            @map("entity_id")
  recipient       String
  status          String
  error           String?
  createdAt       DateTime           @default(now()) @map("created_at")

  organization    Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, ruleId, trigger, entityId, createdAt])
  @@index([orgId, createdAt])
  @@map("alert_deliveries")
}

/// Per-org Slack OAuth app credentials, configured from the UI ("Setup Slack"
/// button). Replaces the previous SLACK_CLIENT_ID / SLACK_CLIENT_SECRET /
/// SLACK_REDIRECT_URI env vars (env vars still work as a fallback when the row
/// is absent, so existing deployments keep working).
model SlackOAuthSettings {
  id                    String   @id @default(uuid())
  orgId                 String   @unique @map("org_id")
  clientId              String   @map("client_id")
  clientSecretEncrypted String   @map("client_secret_encrypted")
  redirectUri           String   @map("redirect_uri")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  organization          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("slack_oauth_settings")
}

/// One Slack workspace per org. `botTokenEncrypted` is xoxb- token from
/// the OAuth v2 flow, encrypted via lib/encryption.ts.
model SlackInstallation {
  id                  String   @id @default(uuid())
  orgId               String   @unique @map("org_id")
  teamId              String   @map("team_id")
  teamName            String   @map("team_name")
  botUserId           String   @map("bot_user_id")
  botTokenEncrypted   String   @map("bot_token_encrypted")
  scopes              String
  installedAt         DateTime @default(now()) @map("installed_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organization        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("slack_installations")
}

/// Microsoft Teams Bot Framework credentials. The user creates an Azure AD App
/// Registration (a.k.a. Microsoft Entra App) plus a client secret, and pastes
/// the App ID and secret here. These are used both to validate inbound
/// activities (Microsoft signs requests with a JWT we verify against
/// `microsoftAppId` as audience) and to mint outbound bearer tokens for
/// proactive messaging.
model TeamsBotSettings {
  id                          String   @id @default(uuid())
  orgId                       String   @unique @map("org_id")
  microsoftAppId              String   @map("microsoft_app_id")
  microsoftAppPasswordEncrypted String @map("microsoft_app_password_encrypted")
  /// Optional Azure AD tenant id for single-tenant bots ("MultiTenant" otherwise).
  tenantId                    String?  @map("tenant_id")
  /// Public base URL of *this* Agent Plutus deployment. Used to render the
  /// `messagingEndpoint` in the generated Teams app manifest. Falls back to
  /// APP_BASE_URL/NEXTAUTH_URL when empty.
  publicBaseUrl               String?  @map("public_base_url")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  organization                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("teams_bot_settings")
}

/// Every Teams scope (channel, 1:1 chat, group chat) the bot has been added
/// to. Populated when Microsoft delivers a `conversationUpdate` activity with
/// `membersAdded` containing the bot. Used to power the channel picker in
/// settings and to address proactive messages.
model TeamsConversation {
  id               String   @id @default(uuid())
  orgId            String   @map("org_id")
  /// Bot Framework conversation id, e.g. `19:meeting_…@thread.v2` for channels.
  conversationId   String   @map("conversation_id")
  /// "channel" | "personal" | "groupChat"
  conversationType String   @map("conversation_type")
  /// Channel/group title, or the user's name for 1:1 chats.
  displayName      String?  @map("display_name")
  /// Team title (for "channel" conversations) or empty.
  teamName         String?  @map("team_name")
  /// Azure AD tenant id of the conversation.
  tenantId         String?  @map("tenant_id")
  /// `https://smba.trafficmanager.net/<region>/` — used as the base URL for
  /// proactive POSTs.
  serviceUrl       String   @map("service_url")
  /// "msteams" almost always.
  channelId        String   @default("msteams") @map("channel_id")
  /// Last activity addressed at this conversation (for diagnostics).
  lastSeenAt       DateTime @default(now()) @map("last_seen_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, conversationId])
  @@index([orgId])
  @@map("teams_conversations")
}
